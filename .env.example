# ============================================================
# Networking Brain — Configuration
# Copy to .env and fill in your values
# ============================================================

# --- LLM ---
LLM_PROVIDER=google                    # google | lmstudio
GOOGLE_API_KEY=                         # API key from Google AI Studio
GOOGLE_LLM_MODEL=gemini-2.5-flash      # gemini-2.5-pro | gemini-2.5-flash
LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1
LMSTUDIO_LLM_MODEL=qwen3.5-3b
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# --- Embeddings ---
EMBED_PROVIDER=google                   # google | lmstudio
GOOGLE_EMBED_MODEL=text-embedding-004
LMSTUDIO_EMBED_MODEL=mxbai-embed-large-v1
EMBED_DIMENSIONS=768

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=crm
POSTGRES_USER=crm
POSTGRES_PASSWORD=          # REQUIRED — use: openssl rand -base64 32

# --- Redis ---
REDIS_PASSWORD=             # REQUIRED — use: openssl rand -base64 24
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# --- Whisper ---
WHISPER_URL=http://whisper:9000
WHISPER_MODEL=small
WHISPER_LANGUAGE=auto

# --- Telegram ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_NAME=crm_session

# --- Application ---
APP_PORT=8000
FRONTEND_PORT=3005
LOG_LEVEL=INFO
SECRET_KEY=              # REQUIRED — use: openssl rand -hex 32
API_KEY=                 # REQUIRED in production — use: openssl rand -hex 32
                         # All /api/* requests must send: Authorization: Bearer <API_KEY>
# Comma-separated list of allowed CORS origins (no wildcards)
CORS_ORIGINS=https://yourdomain.com

# --- Frontend (build-time) ---
VITE_API_URL=/api
# Dedicated frontend API token — SEPARATE from API_KEY (build arg baked into image)
VITE_API_KEY=             # REQUIRED — use: openssl rand -hex 32

# --- Session encryption ---
# Fernet key for encrypting Telegram sessions at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave empty to store sessions unencrypted (not recommended for production).
SESSION_ENCRYPTION_KEY=
